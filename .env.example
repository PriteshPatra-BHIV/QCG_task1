# Copy this file to .env and adjust values as needed.
# All values shown are defaults.

# -- Quantum Producer ---------------------------------------------------------
QCG_SHOTS=1024
QCG_SEED=42
QCG_SUPPORTED_MODES=entangled,direct,superdense
QCG_MAX_MESSAGE_LENGTH=256

# -- Translation Layer --------------------------------------------------------
QCG_CONTRACT_VERSION=1.0.0
QCG_CONFIDENCE_THRESHOLD=0.70
QCG_CORRUPTION_THRESHOLD=0.40

# -- Gateway ------------------------------------------------------------------
QCG_RATE_LIMIT_PER_MINUTE=60

# -- Adapter / Execution Contract Layer ---------------------------------------
QCG_EXEC_CONTRACT_VERSION=2.0.0
QCG_MIN_CONTRACT_VERSION=2.0.0
QCG_ALLOWED_PRODUCERS=CLASSICAL,QUANTUM,HYBRID

# -- Governance ---------------------------------------------------------------
# true = strict mode (halt on any violation)
# false = permissive mode (log violations, continue)
QCG_GOVERNANCE_STRICT=true

# -- Distributed Simulation ---------------------------------------------------
QCG_SIM_NODE_COUNT=3
QCG_SIM_PRODUCER_COUNT=2

# -- Logging ------------------------------------------------------------------
# json (production) | text (development)
QCG_LOG_LEVEL=INFO
QCG_LOG_FORMAT=json
